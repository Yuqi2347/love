<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 统一日志格式：时间 [traceId] 级别 [线程] 类名 - 消息 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-}] %5p [%thread] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- 应用包日志 -->
    <logger name="com.campus.love" level="INFO"/>
    <!-- MyBatis（Slf4jImpl）：SQL 明细为 DEBUG，默认 root=INFO 即不刷屏；调 SQL 时可对具体 mapper 包开 DEBUG -->
    <logger name="org.apache.ibatis" level="INFO"/>
    <!-- 降低 Spring 框架日志噪音 -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>
</configuration>
