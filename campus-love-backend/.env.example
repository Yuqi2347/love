# Core
SERVER_PORT=8082
SERVER_ADDRESS=0.0.0.0

# Database
DB_URL=jdbc:mysql://localhost:3306/your_database?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
# 默认 true：启动时 Flyway 执行 db/migration（V1～V46）。仅本地调试可设为 false
# SPRING_FLYWAY_ENABLED=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=your_mail_account@example.com
MAIL_PASSWORD=your_mail_app_password
MAIL_FROM=your_mail_from@example.com

# JWT（单位：毫秒。604800000 = 7 天）
# 前端请求头只用 access_token、未走 refresh，故 access 与 refresh 建议同为一周
JWT_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRATION=604800000
JWT_REFRESH_EXPIRATION=604800000

# AI（文本对话 / 缘分解析等）
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.example.com/v1
AI_MODEL=your_ai_model
AI_MAX_TOKENS=4096
AI_TIMEOUT=90

# 火山方舟图生图（AI 头像工作室 img2img，与文本 AI 分离）
ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.example.com/api/v3
ARK_IMAGE_MODEL=your_ark_image_model
# 每人免费生成次数（成功调用后计数）
AVATAR_STUDIO_FREE_QUOTA=2
# 图生图 HTTP 超时（秒，含下载结果图）
AVATAR_STUDIO_TIMEOUT_SECONDS=180

# 缘分：1=默认（MySQL 按用户对缓存 + 一小时内仅能对一位「新」互关调 AI；与是否重新登录无关）
# 0=不读库缓存、每次调 AI（易被误认为「冷却失效」）；-1=永久缓存（仍遵守「每对只生成一次」的库记录）
YUANFEN_COOLDOWN=1
# 缘分解析 completion 上限，略低于 AI_MAX_TOKENS 可加快出文；过小可能导致 JSON 被截断
YUANFEN_MAX_TOKENS=3072
# 缘分解析调用厂商 API 超时（秒），与前端 axios 一致；默认 60
# YUANFEN_TIMEOUT=60
# 同对用户进行中锁 TTL（秒）；防对同一好友连点并发
# YUANFEN_INFLIGHT_TTL=120
# 每用户 15 分钟内最多「发起 AI」次数（缓存命中不计；反复取消再点会计数）
# YUANFEN_START_BURST_MAX=8
# YUANFEN_START_BURST_WINDOW=900
# 全站当前小时真实调 AI 的缘分次数上限（上海时区整点小时，Redis）；0=不限制
# YUANFEN_GLOBAL_AI_HOURLY_MAX=120

# Security
APP_ENFORCE_SECRETS=true
APP_ALLOWED_ORIGINS=http://localhost:5179,http://127.0.0.1:5179,http://localhost:5174,http://127.0.0.1:5174
APP_WS_ALLOWED_ORIGINS=http://localhost:5179,http://127.0.0.1:5179,http://localhost:5174,http://127.0.0.1:5174

# WeChat Mini Program（微信小程序登录/绑定）
# 小程序后台 -> 开发管理 -> 开发设置 中获取
WECHAT_MINI_APP_ID=your_wechat_mini_app_id
WECHAT_MINI_APP_SECRET=your_wechat_mini_app_secret
# 一般不用改，默认官方接口
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
# 微信订阅消息（仅推送 3 类：心动结果 / 有人加入邀约 / 等待邀约匹配成功）
WECHAT_SUBSCRIBE_ENABLED=false
# 三个模板ID（小程序后台 -> 订阅消息模板）
WECHAT_SUBSCRIBE_TMPL_PAIR_DATE_RESULT_READY=
WECHAT_SUBSCRIBE_TMPL_INVITE_NEW_PARTICIPANT=
WECHAT_SUBSCRIBE_TMPL_INVITE_MATCH_FOUND=
# 模板字段 key（默认 thing1/time2/thing3；若你选的模板字段不同请改这里）
WECHAT_SUBSCRIBE_DATA_KEY_TITLE=thing1
WECHAT_SUBSCRIBE_DATA_KEY_TIME=time2
WECHAT_SUBSCRIBE_DATA_KEY_REMARK=thing3
# 模板点击后跳转页（小程序内路径）
WECHAT_SUBSCRIBE_PAGE_PAIR_DATE_RESULT_READY=pages/moment/result/result
WECHAT_SUBSCRIBE_PAGE_INVITE_NEW_PARTICIPANT=pages/invite/index/index
WECHAT_SUBSCRIBE_PAGE_INVITE_MATCH_FOUND=pages/invite/wait/wait

# Upload
# 本机绝对路径；留空则默认 ~/campus-love/uploads/。开发时常用：/path/to/campus-love-backend/uploads
# 历史文件若在 uploads/ 根目录平铺，升级分目录后执行一次：./migrate-flat-uploads.sh
APP_UPLOAD_PATH=
